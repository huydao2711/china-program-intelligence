# ══════════════════════════════════════════════════════
# ENV VARS — copy thành .env để chạy local
# Trên Railway: set trong dashboard → Variables
# ══════════════════════════════════════════════════════

# ── Email (bắt buộc) ──────────────────────────────────
# Vào myaccount.google.com → Security → App Passwords → tạo password 16 ký tự
GMAIL_USER=daohuy27112000@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
NOTIFY_EMAIL=daohuy27112000@gmail.com

# ── Google Sheets (tuỳ chọn) ──────────────────────────
# Nếu không set: system chỉ gửi email, không ghi Sheet
# Tạo Service Account: console.cloud.google.com → IAM → Service Accounts
# Download JSON → paste toàn bộ nội dung vào đây (1 dòng)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_SHEET_NAME=WeChat Monitor Log
# URL của Google Sheet để đính kèm trong email (lấy sau khi sheet được tạo lần đầu)
GOOGLE_SHEET_URL=

# ── Optional ──────────────────────────────────────────
# Claude API (dùng cho ecosystem agent — weekly analysis)
ANTHROPIC_API_KEY=

# Cookie Xiaohongshu (lấy từ browser DevTools → Network → Request Headers → cookie)
XHS_COOKIE=
